<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <h1 class="display-4 fw-bold mb-2" style="color:#160438;">500</h1>
                        <h4 class="mb-3">Something went wrong</h4>
                        <p class="text-muted mb-0">
                            The server encountered an unexpected error. Please try again later.
                        </p>
                    </div>

                    {{#if message}}
                    <div class="alert alert-light border text-start small mb-4">
                        <strong>Message:</strong> {{message}}
                    </div>
                    {{/if}}

                    <div class="d-flex justify-content-center gap-2 flex-wrap">
                        <a href="/" class="btn text-white" style="background-color:#160438;">
                            Back to Home
                        </a>
                        <button type="button" class="btn btn-outline-secondary" onclick="location.reload()">
                            Try Again
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>