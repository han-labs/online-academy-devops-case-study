<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <h1 class="display-4 fw-bold mb-2" style="color:#160438;">403</h1>
                        <h4 class="mb-3">Access denied</h4>
                        <p class="text-muted mb-0">
                            You do not have permission to access this page.
                        </p>
                    </div>

                    {{#if error}}
                    <div class="alert alert-warning text-start small mb-4">
                        <strong>Reason:</strong> {{error}}
                    </div>
                    {{/if}}

                    <div class="d-flex justify-content-center gap-2 flex-wrap">
                        <a href="/" class="btn text-white" style="background-color:#160438;">
                            Back to Home
                        </a>
                        <a href="/account/login" class="btn btn-outline-secondary">
                            Log in with another account
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>